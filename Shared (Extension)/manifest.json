{
  "manifest_version": 2,
  "name": "Video Link Catcher",
  "version": "1.0",
  "description": "Detects video streams and prompts to download.",
  "permissions": [
    "webRequest",
    "activeTab",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}
